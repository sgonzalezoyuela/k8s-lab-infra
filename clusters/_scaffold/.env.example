# Cluster-specific .env for __CLUSTER_NAME__.
# Copy this file to .env (gitignored), fill in the secrets, then run
# `just env-check` from inside `nix develop`.
#
# This file mirrors $TOOLS_DIR/.env.example. The shared one is the canonical
# list; this copy exists so operators can scaffold without immediate access
# to the tools directory. If shared keys change, also update them here.

# --- Proxmox ---
PROXMOX_ENDPOINT=https://pve.example.com:8006/api2/json
PROXMOX_INSECURE=false
PROXMOX_NODE=pve
PROXMOX_API_TOKEN_ID=root@pam!terraform
PROXMOX_API_TOKEN_SECRET=
PROXMOX_STORAGE_POOL=local-lvm
PROXMOX_ISO_STORAGE=local
PROXMOX_SNIPPET_STORAGE=local

PROXMOX_SSH_USER=root
PROXMOX_SSH_HOST=pve.example.com
PROXMOX_SNIPPETS_DIR=/var/lib/vz/snippets

# --- Cluster identity ---
CLUSTER_NAME=__CLUSTER_NAME__
CLUSTER_DOMAIN=__CLUSTER_NAME__.example.com

# --- Nodes ---
CP_HOSTNAME=cp.__CLUSTER_NAME__.example.com
CP_IP=10.4.0.1
WK0_HOSTNAME=wk0.__CLUSTER_NAME__.example.com
WK0_IP=10.4.0.10

# --- Network ---
NETWORK_CIDR=24
NETWORK_GATEWAY=10.0.0.1
NETWORK_DNS=10.0.1.77
NETWORK_BRIDGE=vmbr0

# --- VM sizing ---
CP_CORES=4
CP_MEMORY_MB=4096
CP_DISK_SIZE_GB=30
WK_CORES=8
WK_MEMORY_MB=8192
WK_DISK_SIZE_GB=30
WK_STORAGE_DISK_SIZE_GB=200

# --- Talos ---
# TALOS_VERSION is exported by the cluster's flake.nix shellHook; do not
# duplicate it here.
TALOS_IMAGE_PLATFORM=nocloud

# --- Phase 2 ---
METALLB_RANGE=10.4.200.0/24
CA_CERT_PATH=secrets/ca.crt
CA_KEY_PATH=secrets/ca.key
