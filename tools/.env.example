# --- Proxmox ---
PROXMOX_ENDPOINT=https://emcc.lab.atricore.io:8006/api2/json
PROXMOX_INSECURE=false                       # set true if using self-signed cert
PROXMOX_NODE=emcc                            # target node name in cluster
PROXMOX_API_TOKEN_ID=root@pam!terraform      # API token id
PROXMOX_API_TOKEN_SECRET=                    # UUID, REQUIRED, leave blank in example
PROXMOX_STORAGE_POOL=local-lvm               # VM disk storage
PROXMOX_ISO_STORAGE=local                    # ISO storage (must support iso content)
PROXMOX_SNIPPET_STORAGE=local                # storage with snippets content for NoCloud user-data

# Proxmox API does NOT support snippet uploads; the operator copies them via
# scp. The build/render flow prints the exact commands using the values below.
PROXMOX_SSH_USER=root                        # SSH user on the Proxmox host
PROXMOX_SSH_HOST=emcc.lab.atricore.io        # SSH target (host or IP); usually same machine as PROXMOX_ENDPOINT
PROXMOX_SNIPPETS_DIR=/var/lib/vz/snippets    # filesystem path backing PROXMOX_SNIPPET_STORAGE

# --- Cluster identity ---
CLUSTER_NAME=k8s4
CLUSTER_DOMAIN=k8s4.lab.atricore.io

# --- Nodes ---
CP_HOSTNAME=cp.k8s4.lab.atricore.io
CP_IP=10.4.0.1
WK0_HOSTNAME=wk0.k8s4.lab.atricore.io
WK0_IP=10.4.0.10

# --- Network ---
NETWORK_CIDR=8                               # flat /8 lab network (10.0.0.0/8); gateway must be on-link from node IPs
NETWORK_GATEWAY=10.0.0.1
NETWORK_DNS=10.0.1.77
NETWORK_BRIDGE=vmbr0

# --- Control-plane VM sizing ---
CP_CORES=4
CP_MEMORY_MB=4096
CP_DISK_SIZE_GB=30                           # OS disk

# --- Worker VM sizing ---
WK_CORES=8
WK_MEMORY_MB=8192
WK_DISK_SIZE_GB=30                           # OS disk
WK_STORAGE_DISK_SIZE_GB=200                  # second disk attached to workers, used by Longhorn

# --- Talos ---
# NOTE: TALOS_VERSION is intentionally NOT here. It is per-cluster, exported by
# each cluster's flake.nix shellHook (see clusters/<name>/flake.nix). Bump it
# in lockstep with that flake's nixpkgs input (which pins talosctl).
TALOS_IMAGE_PLATFORM=nocloud                 # required: Talos NoCloud Image Factory platform

# --- Phase 2 (forward-declared, unused in Phase 1) ---
METALLB_RANGE=10.4.200.0/24
# METALLB_CHART_VERSION pins the metallb/metallb Helm chart per cluster. The
# chart's own version (no `v` prefix; differs from cert-manager). Bumping
# requires editing both this file (per cluster) and
# tools/cluster/metallb/chart-version.txt (the bundled default).
METALLB_CHART_VERSION=0.15.3
CA_CERT_PATH=secrets/ca.crt
CA_KEY_PATH=secrets/ca.key

# --- Phase 2: cert-manager ---
# CLUSTER_ISSUER_NAME is the name of both the ClusterIssuer and the TLS Secret
# carrying the CA materials in the cert-manager namespace. Default atricore-ca.
CLUSTER_ISSUER_NAME=atricore-ca
# CERT_MANAGER_CHART_VERSION pins the Jetstack cert-manager Helm chart per
# cluster. Bumping requires editing both this file (per cluster) and
# tools/cluster/cert-manager/chart-version.txt (the bundled default).
CERT_MANAGER_CHART_VERSION=v1.16.2

# --- Phase 2: newt (Pangolin tunnel client) ---
# Egress-only userspace WireGuard tunnel client (fosrl/newt) that connects
# from inside the cluster to a Pangolin server. Credentials are issued by
# Pangolin's site UI; install.sh refuses to apply REPLACE-ME placeholders.
PANGOLIN_ENDPOINT=https://app.pangolin.net
NEWT_ID=                                     # REQUIRED, paste from Pangolin site UI
NEWT_SECRET=                                 # REQUIRED, paste from Pangolin site UI
# NEWT_IMAGE_TAG pins the fosrl/newt image. Bumping requires editing both
# this file (per cluster) and tools/cluster/newt/image-tag.txt (the bundled
# default). No `v` prefix — newt's container tags are bare semver.
NEWT_IMAGE_TAG=1.12.3
